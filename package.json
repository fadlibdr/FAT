{
  "name": "fat",
  "version": "0.1.0",
  "private": true,
  "description": "FAT — an ERPNext-style ERP built as a modular monolith (TypeScript + NestJS)",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "backend:migration:run": "pnpm --filter @fat/shared build && pnpm --filter @fat/backend migration:run",
    "backend:seed": "pnpm --filter @fat/shared build && pnpm --filter @fat/backend seed"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
