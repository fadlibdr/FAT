# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=fat
DATABASE_PASSWORD=fat
DATABASE_NAME=fat

# Backend
BACKEND_PORT=3001

# Auth
JWT_SECRET=change-me-in-production-please
JWT_ACCESS_EXPIRES=1h
JWT_REFRESH_EXPIRES=7d

# Administrator bootstrap (created by seed)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin

# Background jobs (optional). Leave REDIS_HOST unset to run jobs inline.
# Set REDIS_HOST=localhost (after `docker compose up -d redis`) to use BullMQ.
# REDIS_HOST=localhost
# REDIS_PORT=6379

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
