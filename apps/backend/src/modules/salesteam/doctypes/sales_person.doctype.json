{
  "name": "Sales Person",
  "module": "Salesteam",
  "naming_rule": "field:sales_person_name",
  "title_field": "sales_person_name",
  "fields": [
    { "fieldname": "sales_person_name", "label": "Sales Person Name", "fieldtype": "Data", "reqd": true, "in_list_view": true },
    { "fieldname": "commission_rate", "label": "Commission Rate (%)", "fieldtype": "Float", "default": "5", "in_list_view": true },
    { "fieldname": "target_amount", "label": "Target Amount", "fieldtype": "Currency", "in_list_view": true },
    { "fieldname": "total_sales", "label": "Total Sales", "fieldtype": "Currency", "read_only": true, "in_list_view": true },
    { "fieldname": "total_commission", "label": "Total Commission", "fieldtype": "Currency", "read_only": true, "in_list_view": true }
  ],
  "permissions": [
    { "role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "report": 1 },
    { "role": "Sales User", "read": 1, "write": 1, "create": 1, "report": 1 }
  ]
}
