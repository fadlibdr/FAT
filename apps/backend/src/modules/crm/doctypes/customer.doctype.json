    { "fieldname": "territory", "label": "Territory", "fieldtype": "Link", "options": "Territory", "in_standard_filter": true },
    { "fieldname": "email_id", "label": "Email", "fieldtype": "Data", "in_list_view": true },
    { "fieldname": "mobile_no", "label": "Mobile", "fieldtype": "Data" },
    { "fieldname": "credit_limit", "label": "Credit Limit", "fieldtype": "Currency" }
