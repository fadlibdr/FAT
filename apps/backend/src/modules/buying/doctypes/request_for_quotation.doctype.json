{
  "name": "Request for Quotation",
  "module": "Buying",
  "naming_rule": "series:RFQ-.#####",
  "is_submittable": true,
  "title_field": "transaction_date",
  "fields": [
    { "fieldname": "transaction_date", "label": "Date", "fieldtype": "Date", "reqd": true, "in_list_view": true },
    { "fieldname": "company", "label": "Company", "fieldtype": "Link", "options": "Company", "in_standard_filter": true },
    { "fieldname": "material_request", "label": "Material Request", "fieldtype": "Link", "options": "Material Request", "read_only": true, "in_standard_filter": true },
    { "fieldname": "items", "label": "Items", "fieldtype": "Table", "options": "Request for Quotation Item" },
    { "fieldname": "suppliers", "label": "Suppliers", "fieldtype": "Table", "options": "Request for Quotation Supplier" },
    { "fieldname": "status", "label": "Status", "fieldtype": "Select", "options": "Draft\nSubmitted\nCancelled", "default": "Draft", "read_only": true, "in_list_view": true, "in_standard_filter": true }
  ],
  "permissions": [
    { "role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "submit": 1, "cancel": 1, "report": 1 },
    { "role": "Purchase User", "read": 1, "write": 1, "create": 1, "submit": 1, "report": 1 }
  ]
}
