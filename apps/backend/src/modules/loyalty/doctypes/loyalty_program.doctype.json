{
  "name": "Loyalty Program",
  "module": "Loyalty",
  "naming_rule": "field:program_name",
  "title_field": "program_name",
  "fields": [
    { "fieldname": "program_name", "label": "Program Name", "fieldtype": "Data", "reqd": true, "in_list_view": true },
    { "fieldname": "is_active", "label": "Is Active", "fieldtype": "Check", "default": "1", "in_list_view": true, "in_standard_filter": true },
    { "fieldname": "is_default", "label": "Is Default", "fieldtype": "Check", "default": "1", "in_list_view": true },
    { "fieldname": "collection_factor", "label": "Points per Currency", "fieldtype": "Float", "default": "0", "reqd": true, "in_list_view": true },
    { "fieldname": "redemption_factor", "label": "Currency per Point", "fieldtype": "Float", "default": "0", "in_list_view": true }
  ],
  "permissions": [
    { "role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "report": 1 },
    { "role": "Sales User", "read": 1, "write": 1, "create": 1, "report": 1 }
  ]
}
