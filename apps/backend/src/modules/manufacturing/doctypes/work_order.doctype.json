{
  "name": "Work Order",
  "module": "Manufacturing",
  "naming_rule": "series:WO-.#####",
  "is_submittable": true,
  "title_field": "production_item",
  "fields": [
    { "fieldname": "production_item", "label": "Production Item", "fieldtype": "Link", "options": "Item", "reqd": true, "in_list_view": true, "in_standard_filter": true },
    { "fieldname": "bom", "label": "BOM", "fieldtype": "Link", "options": "BOM", "reqd": true, "in_list_view": true },
    { "fieldname": "qty", "label": "Qty to Manufacture", "fieldtype": "Float", "default": "1", "reqd": true, "in_list_view": true },
    { "fieldname": "source_warehouse", "label": "Source Warehouse", "fieldtype": "Link", "options": "Warehouse" },
    { "fieldname": "fg_warehouse", "label": "Target Warehouse", "fieldtype": "Link", "options": "Warehouse" },
    { "fieldname": "company", "label": "Company", "fieldtype": "Link", "options": "Company", "in_standard_filter": true },
    { "fieldname": "status", "label": "Status", "fieldtype": "Select", "options": "Draft\nIn Process\nCompleted\nCancelled", "default": "Draft", "read_only": true, "in_list_view": true, "in_standard_filter": true },
    { "fieldname": "stock_entry", "label": "Manufacture Entry", "fieldtype": "Data", "read_only": true },
    { "fieldname": "produced_value", "label": "Produced Value", "fieldtype": "Currency", "read_only": true }
  ],
  "permissions": [
    { "role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "submit": 1, "cancel": 1, "report": 1 },
    { "role": "Stock User", "read": 1, "write": 1, "create": 1, "submit": 1, "report": 1 }
  ]
}
