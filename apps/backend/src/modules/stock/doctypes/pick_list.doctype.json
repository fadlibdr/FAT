{
  "name": "Pick List",
  "module": "Stock",
  "naming_rule": "series:PICK-.#####",
  "is_submittable": true,
  "title_field": "customer",
  "fields": [
    { "fieldname": "customer", "label": "Customer", "fieldtype": "Link", "options": "Customer", "in_list_view": true, "in_standard_filter": true },
    { "fieldname": "posting_date", "label": "Posting Date", "fieldtype": "Date", "reqd": true, "in_list_view": true },
    { "fieldname": "sales_order", "label": "Sales Order", "fieldtype": "Link", "options": "Sales Order", "read_only": true, "in_standard_filter": true },
    { "fieldname": "locations", "label": "Locations", "fieldtype": "Table", "options": "Pick List Item", "reqd": true },
    { "fieldname": "delivery_note", "label": "Delivery Note", "fieldtype": "Link", "options": "Delivery Note", "read_only": true, "in_list_view": true },
    { "fieldname": "status", "label": "Status", "fieldtype": "Select", "options": "Draft\nPicked\nDelivered\nCancelled", "default": "Draft", "in_list_view": true }
  ],
  "permissions": [
    { "role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "submit": 1, "cancel": 1, "report": 1 },
    { "role": "Stock User", "read": 1, "write": 1, "create": 1, "submit": 1, "report": 1 }
  ]
}
