{
  "name": "Stock Ledger Entry",
  "module": "Stock",
  "naming_rule": "series:SLE-.#####",
  "title_field": "item_code",
  "fields": [
    { "fieldname": "posting_date", "label": "Posting Date", "fieldtype": "Date", "reqd": true, "in_list_view": true, "in_standard_filter": true },
    { "fieldname": "item_code", "label": "Item", "fieldtype": "Link", "options": "Item", "reqd": true, "in_list_view": true, "in_standard_filter": true },
    { "fieldname": "warehouse", "label": "Warehouse", "fieldtype": "Link", "options": "Warehouse", "in_list_view": true, "in_standard_filter": true },
    { "fieldname": "batch_no", "label": "Batch", "fieldtype": "Data", "in_list_view": true, "in_standard_filter": true },
    { "fieldname": "actual_qty", "label": "Actual Qty", "fieldtype": "Float", "in_list_view": true },
    { "fieldname": "valuation_rate", "label": "Valuation Rate", "fieldtype": "Currency", "in_list_view": true },
    { "fieldname": "qty_after_transaction", "label": "Qty After Transaction", "fieldtype": "Float" },
    { "fieldname": "stock_value", "label": "Stock Value Change", "fieldtype": "Currency" },
    { "fieldname": "voucher_type", "label": "Voucher Type", "fieldtype": "Data", "in_standard_filter": true },
    { "fieldname": "voucher_no", "label": "Voucher No", "fieldtype": "Data", "in_list_view": true, "in_standard_filter": true }
  ],
  "permissions": [
    { "role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "report": 1 },
    { "role": "Stock User", "read": 1, "report": 1 }
  ]
}
