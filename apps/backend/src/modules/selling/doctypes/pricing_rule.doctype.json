{
  "name": "Pricing Rule",
  "module": "Selling",
  "naming_rule": "series:PRLE-.#####",
  "title_field": "title",
  "fields": [
    { "fieldname": "title", "label": "Title", "fieldtype": "Data", "reqd": true, "in_list_view": true },
    { "fieldname": "is_active", "label": "Is Active", "fieldtype": "Check", "default": "1", "in_list_view": true, "in_standard_filter": true },
    { "fieldname": "priority", "label": "Priority", "fieldtype": "Int", "default": "0", "in_list_view": true },
    { "fieldname": "apply_on", "label": "Apply On", "fieldtype": "Select", "options": "Item Code\nItem Group", "default": "Item Code", "reqd": true, "in_standard_filter": true },
    { "fieldname": "item_code", "label": "Item", "fieldtype": "Link", "options": "Item", "in_list_view": true },
    { "fieldname": "item_group", "label": "Item Group", "fieldtype": "Link", "options": "Item Group" },
    { "fieldname": "customer", "label": "Customer", "fieldtype": "Link", "options": "Customer", "in_standard_filter": true },
    { "fieldname": "min_qty", "label": "Min Qty", "fieldtype": "Float", "default": "0" },
    { "fieldname": "rate_or_discount", "label": "Action", "fieldtype": "Select", "options": "Discount Percentage\nRate", "default": "Discount Percentage", "reqd": true, "in_list_view": true },
    { "fieldname": "discount_percentage", "label": "Discount %", "fieldtype": "Float", "default": "0", "in_list_view": true },
    { "fieldname": "rate", "label": "Rate", "fieldtype": "Currency" }
  ],
  "permissions": [
    { "role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "report": 1 },
    { "role": "Sales User", "read": 1, "write": 1, "create": 1, "report": 1 }
  ]
