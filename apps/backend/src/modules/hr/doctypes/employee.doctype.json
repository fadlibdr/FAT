    { "fieldname": "date_of_joining", "label": "Date of Joining", "fieldtype": "Date", "in_list_view": true },
    { "fieldname": "status", "label": "Status", "fieldtype": "Select", "options": "Active\nInactive\nLeft", "default": "Active", "in_list_view": true, "in_standard_filter": true }
