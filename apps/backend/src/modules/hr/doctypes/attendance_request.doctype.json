{
  "name": "Attendance Request",
  "module": "HR",
  "naming_rule": "series:ATTREQ-.#####",
  "title_field": "employee",
  "fields": [
    { "fieldname": "employee", "label": "Employee", "fieldtype": "Link", "options": "Employee", "reqd": true, "in_list_view": true, "in_standard_filter": true },
    { "fieldname": "from_date", "label": "From Date", "fieldtype": "Date", "reqd": true, "in_list_view": true },
    { "fieldname": "to_date", "label": "To Date", "fieldtype": "Date", "reqd": true, "in_list_view": true },
    { "fieldname": "attendance_status", "label": "Mark As", "fieldtype": "Select", "options": "Present\nHalf Day", "default": "Present", "in_list_view": true },
    { "fieldname": "reason", "label": "Reason", "fieldtype": "Small Text" },
    { "fieldname": "request_status", "label": "Request Status", "fieldtype": "Select", "options": "Draft\nApproved\nRejected", "default": "Draft", "read_only": true, "in_list_view": true, "in_standard_filter": true }
  ],
  "permissions": [
    { "role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "report": 1 },
    { "role": "HR User", "read": 1, "write": 1, "create": 1, "report": 1 }
  ]
}
