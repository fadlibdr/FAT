{
  "name": "Employee Advance",
  "module": "HR",
  "naming_rule": "series:EADV-.#####",
  "is_submittable": true,
  "title_field": "employee",
  "fields": [
    { "fieldname": "employee", "label": "Employee", "fieldtype": "Link", "options": "Employee", "reqd": true, "in_list_view": true, "in_standard_filter": true },
    { "fieldname": "posting_date", "label": "Posting Date", "fieldtype": "Date", "reqd": true, "in_list_view": true },
    { "fieldname": "company", "label": "Company", "fieldtype": "Link", "options": "Company", "in_standard_filter": true },
    { "fieldname": "purpose", "label": "Purpose", "fieldtype": "Data" },
    { "fieldname": "advance_amount", "label": "Advance Amount", "fieldtype": "Currency", "reqd": true, "in_list_view": true },
    { "fieldname": "advance_account", "label": "Advance Account", "fieldtype": "Link", "options": "Account", "default": "Employee Advance" },
    { "fieldname": "paid_from", "label": "Paid From", "fieldtype": "Link", "options": "Account", "default": "Cash" },
    { "fieldname": "claimed_amount", "label": "Claimed Amount", "fieldtype": "Currency", "read_only": true, "default": "0", "in_list_view": true },
    { "fieldname": "returned_amount", "label": "Returned Amount", "fieldtype": "Currency", "read_only": true, "default": "0", "in_list_view": true },
    { "fieldname": "status", "label": "Status", "fieldtype": "Select", "options": "Draft\nPaid\nClaimed\nCancelled", "default": "Draft", "read_only": true, "in_standard_filter": true }
  ],
  "permissions": [
    { "role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "submit": 1, "cancel": 1, "report": 1 },
    { "role": "HR User", "read": 1, "write": 1, "create": 1, "submit": 1, "cancel": 1, "report": 1 },
    { "role": "Accounts User", "read": 1, "report": 1 }
  ]
}
