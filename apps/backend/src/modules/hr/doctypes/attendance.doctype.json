{
  "name": "Attendance",
  "module": "HR",
  "naming_rule": "series:ATT-.#####",
  "title_field": "employee",
  "fields": [
    { "fieldname": "employee", "label": "Employee", "fieldtype": "Link", "options": "Employee", "reqd": true, "in_list_view": true, "in_standard_filter": true },
    { "fieldname": "attendance_date", "label": "Date", "fieldtype": "Date", "reqd": true, "in_list_view": true },
    { "fieldname": "status", "label": "Status", "fieldtype": "Select", "options": "Present\nAbsent\nHalf Day\nOn Leave", "default": "Present", "reqd": true, "in_list_view": true, "in_standard_filter": true },
    { "fieldname": "leave_application", "label": "Leave Application", "fieldtype": "Link", "options": "Leave Application", "read_only": true, "in_standard_filter": true },
    { "fieldname": "shift", "label": "Shift", "fieldtype": "Link", "options": "Shift Type", "in_standard_filter": true },
    { "fieldname": "check_in", "label": "Check In", "fieldtype": "Datetime" },
    { "fieldname": "check_out", "label": "Check Out", "fieldtype": "Datetime" },
    { "fieldname": "working_hours", "label": "Working Hours", "fieldtype": "Float", "read_only": true, "in_list_view": true },
    { "fieldname": "company", "label": "Company", "fieldtype": "Link", "options": "Company", "in_standard_filter": true }
  ],
  "permissions": [
    { "role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "report": 1 },
    { "role": "HR User", "read": 1, "write": 1, "create": 1, "delete": 1, "report": 1 }
  ]
}
