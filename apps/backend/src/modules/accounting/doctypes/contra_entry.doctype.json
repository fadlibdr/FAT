    { "fieldname": "to_account", "label": "To Account", "fieldtype": "Link", "options": "Account", "reqd": true, "in_list_view": true, "in_standard_filter": true },
    { "fieldname": "amount", "label": "Amount", "fieldtype": "Currency", "reqd": true, "in_list_view": true },
    { "fieldname": "remark", "label": "Remark", "fieldtype": "Data" },
    { "fieldname": "status", "label": "Status", "fieldtype": "Select", "options": "Draft\nSubmitted\nCancelled", "default": "Draft", "read_only": true, "in_standard_filter": true }
  ],
  "permissions": [
    { "role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "submit": 1, "cancel": 1, "report": 1 },
    { "role": "Accounts User", "read": 1, "write": 1, "create": 1, "submit": 1, "cancel": 1, "report": 1 }
  ]
