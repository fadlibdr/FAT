{
  "name": "Contra Entry",
  "module": "Accounting",
  "naming_rule": "series:CE-.#####",
  "is_submittable": true,
  "title_field": "from_account",
  "fields": [
    { "fieldname": "posting_date", "label": "Posting Date", "fieldtype": "Date", "reqd": true, "in_list_view": true },
