{
  "name": "Purchase Invoice",
  "module": "Accounting",
  "naming_rule": "series:PINV-.#####",
  "is_submittable": true,
  "title_field": "supplier",
  "fields": [
    { "fieldname": "supplier", "label": "Supplier", "fieldtype": "Link", "options": "Supplier", "reqd": true, "in_list_view": true, "in_standard_filter": true },
    { "fieldname": "posting_date", "label": "Posting Date", "fieldtype": "Date", "reqd": true, "in_list_view": true },
    { "fieldname": "due_date", "label": "Due Date", "fieldtype": "Date" },
    { "fieldname": "is_return", "label": "Is Return (Debit Note)", "fieldtype": "Check", "in_standard_filter": true },
    { "fieldname": "return_against", "label": "Return Against", "fieldtype": "Link", "options": "Purchase Invoice" },
    { "fieldname": "purchase_order", "label": "Purchase Order", "fieldtype": "Link", "options": "Purchase Order", "in_standard_filter": true },
    { "fieldname": "credit_to", "label": "Credit To", "fieldtype": "Link", "options": "Account", "default": "Creditors" },
    { "fieldname": "expense_account", "label": "Expense Account", "fieldtype": "Link", "options": "Account", "default": "Cost of Goods Sold" },
    { "fieldname": "cost_center", "label": "Cost Center", "fieldtype": "Link", "options": "Cost Center", "in_standard_filter": true },
    { "fieldname": "project", "label": "Project", "fieldtype": "Link", "options": "Project", "in_standard_filter": true },
    { "fieldname": "apply_tds", "label": "Apply Tax Withholding", "fieldtype": "Check", "default": "0" },
    { "fieldname": "tax_withholding_category", "label": "Tax Withholding Category", "fieldtype": "Link", "options": "Tax Withholding Category", "in_standard_filter": true },
    { "fieldname": "tds_amount", "label": "Tax Withheld", "fieldtype": "Currency", "read_only": true },
    { "fieldname": "currency", "label": "Currency", "fieldtype": "Link", "options": "Currency" },
    { "fieldname": "conversion_rate", "label": "Exchange Rate", "fieldtype": "Float", "default": "1" },
    { "fieldname": "payment_terms_template", "label": "Payment Terms Template", "fieldtype": "Link", "options": "Payment Terms Template" },
    { "fieldname": "items", "label": "Items", "fieldtype": "Table", "options": "Purchase Invoice Item" },
    { "fieldname": "total", "label": "Net Total", "fieldtype": "Currency", "read_only": true },
    { "fieldname": "taxes_template", "label": "Taxes Template", "fieldtype": "Link", "options": "Purchase Taxes Template" },
    { "fieldname": "taxes", "label": "Taxes and Charges", "fieldtype": "Table", "options": "Purchase Taxes and Charges" },
    { "fieldname": "total_taxes_and_charges", "label": "Total Taxes", "fieldtype": "Currency", "read_only": true },
    { "fieldname": "grand_total", "label": "Grand Total", "fieldtype": "Currency", "read_only": true, "in_list_view": true },
    { "fieldname": "base_grand_total", "label": "Grand Total (Base)", "fieldtype": "Currency", "read_only": true },
    { "fieldname": "payment_schedule", "label": "Payment Schedule", "fieldtype": "Table", "options": "Payment Schedule" },
    { "fieldname": "outstanding_amount", "label": "Outstanding", "fieldtype": "Currency", "read_only": true, "in_list_view": true },
    { "fieldname": "status", "label": "Status", "fieldtype": "Select", "options": "Draft\nUnpaid\nPaid\nReturn\nCancelled", "default": "Draft", "in_list_view": true, "in_standard_filter": true }
  ],
  "permissions": [
    { "role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "submit": 1, "cancel": 1, "report": 1 },
    { "role": "Accounts User", "read": 1, "write": 1, "create": 1, "submit": 1, "report": 1 },
    { "role": "Purchase User", "read": 1, "report": 1 }
  ]
}
