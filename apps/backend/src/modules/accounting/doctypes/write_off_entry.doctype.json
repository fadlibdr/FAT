{
  "name": "Write Off Entry",
  "module": "Accounting",
  "naming_rule": "series:WO-.#####",
  "is_submittable": true,
  "title_field": "customer",
  "fields": [
    { "fieldname": "posting_date", "label": "Posting Date", "fieldtype": "Date", "reqd": true, "in_list_view": true },
    { "fieldname": "customer", "label": "Customer", "fieldtype": "Link", "options": "Customer", "reqd": true, "in_list_view": true, "in_standard_filter": true },
    { "fieldname": "sales_invoice", "label": "Sales Invoice", "fieldtype": "Link", "options": "Sales Invoice", "in_list_view": true, "in_standard_filter": true },
    { "fieldname": "write_off_amount", "label": "Write Off Amount", "fieldtype": "Currency", "in_list_view": true },
    { "fieldname": "write_off_account", "label": "Write Off Account", "fieldtype": "Link", "options": "Account", "default": "Bad Debt Expense" },
    { "fieldname": "debtors_account", "label": "Debtors Account", "fieldtype": "Link", "options": "Account", "default": "Debtors" },
    { "fieldname": "reason", "label": "Reason", "fieldtype": "Data" },
    { "fieldname": "status", "label": "Status", "fieldtype": "Select", "options": "Draft\nSubmitted\nCancelled", "default": "Draft", "read_only": true, "in_standard_filter": true }
  ],
  "permissions": [
    { "role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "submit": 1, "cancel": 1, "report": 1 },
    { "role": "Accounts User", "read": 1, "write": 1, "create": 1, "submit": 1, "cancel": 1, "report": 1 }
  ]
}
