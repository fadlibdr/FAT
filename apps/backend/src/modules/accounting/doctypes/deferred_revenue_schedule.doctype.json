    { "fieldname": "total_amount", "label": "Total Amount", "fieldtype": "Currency", "reqd": true, "in_list_view": true },
    { "fieldname": "start_date", "label": "Recognition Start", "fieldtype": "Date", "reqd": true },
    { "fieldname": "months", "label": "Months", "fieldtype": "Int", "reqd": true, "default": "12" },
    { "fieldname": "debit_account", "label": "Receivable Account", "fieldtype": "Link", "options": "Account", "default": "Debtors" },
    { "fieldname": "deferred_account", "label": "Deferred Revenue Account", "fieldtype": "Link", "options": "Account", "default": "Deferred Revenue" },
    { "fieldname": "income_account", "label": "Income Account", "fieldtype": "Link", "options": "Account", "default": "Sales" },
